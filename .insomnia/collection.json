    },
    {
      "_id": "req_signup",
      "_type": "request",
      "parentId": "fld_signup",
      "name": "POST /auth/signup/",
      "method": "POST",
      "url": "{{ base_url }}/auth/signup/",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"identifier\": \"{{ email }}\",\n  \"password\": \"{{ password }}\",\n  \"method\": \"email\"\n}"
      },
      "headers": [{"name": "Content-Type", "value": "application/json"}]
    },
    {
      "_id": "req_signup_otp",
      "_type": "request",
